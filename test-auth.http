@baseUrl = http://localhost:8080/api
@username = persistentUser2
@password = 1234

# =====================================================
# 🔐 AUTH - REGISTER (Persistent User for Login Flow)
# =====================================================
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}",
  "companyName": "Persistent Co"
}

###

# =====================================================
# 🔐 AUTH - LOGIN (Capture Token)
# =====================================================
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

> {%
    console.log("LOGIN RESPONSE BODY:", response.body);
    console.log("TOKEN BEING SAVED:", response.body.data);

    // Your ApiResponse returns: { status, data, message }
    client.global.set("authToken", response.body.data);
%}

###

