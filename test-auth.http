@baseUrl = http://localhost:8080
@username = persistentUser2
@password = 1234
@authToken = eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiJwZXJzaXN0ZW50VXNlcjIiLCJpYXQiOjE3ODE4MjMzMzYsImV4cCI6MTc4MTgyNjkzNn0.NLtsAZM0vSonnrcXcNyp34CnnqaF6fNmJLBRHr7jXNGND4ZXFSQq3vDbr-mAyfPtYK33hdhahFiCs_EAA0Lu_A
@invalidToken = expiredToken123

# =====================================================
# 🔐 AUTH - REGISTER (Persistent User for Login Flow)
# =====================================================
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}",
  "companyName": "Persistent Co"
}

###

# =====================================================
# 🔐 AUTH - LOGIN (Capture Token)
# =====================================================
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

> {%
    console.log("LOGIN RESPONSE BODY:", response.body);
    console.log("TOKEN BEING SAVED:", response.body.data);

    // Store JWT token for reuse
    client.global.set("authToken", response.body.data);
%}

###

# =====================================================
# 🔒 AUTH - ACCESS PROTECTED ROUTE (VALID TOKEN)
# =====================================================
GET {{baseUrl}}/api/vehicles
Authorization: Bearer {{authToken}}

###

# =====================================================
# ❌ AUTH - MALFORMED AUTH HEADER
# =====================================================

GET {{baseUrl}}/api/vehicles
Authorization: abc123

###

# =====================================================
# ❌ AUTH - LOGIN (Wrong Password)
# =====================================================
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "wrongPassword"
}

###

# =====================================================
# ❌ AUTH - REGISTER (Invalid Input Validation Test)
# =====================================================
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "",
  "password": "",
  "companyName": ""
}

###

# =====================================================
# 🧪 AUTH - REGISTER (Unique User Test)
# =====================================================
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "user_{{$timestamp}}",
  "password": "{{password}}",
  "companyName": "Test Company"
}

###

# =====================================================
# ❌ AUTH - ACCESS PROTECTED ROUTE (NO TOKEN)
# =====================================================
GET {{baseUrl}}/api/vehicles

###

# =====================================================
# ❌ AUTH - ACCESS PROTECTED ROUTE (INVALID TOKEN)
# =====================================================
GET {{baseUrl}}/api/vehicles
Authorization: Bearer {{invalidToken}}

###

# =====================================================
# 🚗 VEHICLE - CREATE (Authenticated)
# =====================================================
POST {{baseUrl}}/api/vehicles
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "title": "Manual Test Vehicle",
  "make": "Toyota",
  "model": "Corolla",
  "vehicleYear": 2022,
  "location": "Test Garage",
  "maintenanceAlertsEnabled": true,
  "startDate": "2026-05-01",
  "endDate": "2026-12-31"
}

> {%
    console.log("CREATED VEHICLE:", response.body);
    client.global.set("vehicleId", response.body.data.id);
%}


###

# =====================================================
# 🚗 VEHICLE - GET BY ID
# =====================================================
GET {{baseUrl}}/api/vehicles/2
Authorization: Bearer {{authToken}}

###

# =====================================================
# 🚗 VEHICLE - UPDATE
# =====================================================
PUT {{baseUrl}}/api/vehicles/2
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "title": "Updated Manual Vehicle",
  "make": "Toyota",
  "model": "Camry",
  "vehicleYear": 2023,
  "location": "Updated Garage",
  "maintenanceAlertsEnabled": false,
  "startDate": "2026-05-01",
  "endDate": "2026-12-31"
}

###

# =====================================================
# 🚗 VEHICLE - SEARCH
# =====================================================
GET {{baseUrl}}/api/vehicles/search?q=Manual&page=0&size=10
Authorization: Bearer {{authToken}}

###

# =====================================================
# 🚗 VEHICLE - DELETE
# =====================================================
DELETE {{baseUrl}}/api/vehicles/2
Authorization: Bearer {{authToken}}

###

