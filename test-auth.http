@baseUrl = http://localhost:8080/api
@username = persistentUser2
@password = 1234

# =====================================================
# 🔐 AUTH - REGISTER (Persistent User for Login Flow)
# =====================================================
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}",
  "companyName": "Persistent Co"
}

###

# =====================================================
# 🔐 AUTH - LOGIN (Capture Token)
# =====================================================
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

> {%
    console.log("LOGIN RESPONSE BODY:", response.body);
    console.log("TOKEN BEING SAVED:", response.body.data);

    // Store JWT token for reuse
    client.global.set("authToken", response.body.data);
%}

###

# =====================================================
# 🔒 AUTH - ACCESS PROTECTED ROUTE (VALID TOKEN)
# =====================================================
GET {{baseUrl}}/vehicles
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiJwZXJzaXN0ZW50VXNlcjIiLCJpYXQiOjE3Nzc0MjYxMDQsImV4cCI6MTc3NzQyOTcwNH0.F6BKIgnfVmhJezMEM9s9ayFLbf6BAhQGXRmeSNI0K8vE2ERM4GBcjTzSVQgugb65

###

# =====================================================
# ❌ AUTH - LOGIN (Wrong Password)
# =====================================================
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "wrongPassword"
}

###

# =====================================================
# ❌ AUTH - REGISTER (Invalid Input Validation Test)
# =====================================================
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "",
  "password": "",
  "companyName": ""
}

###

# =====================================================
# 🧪 AUTH - REGISTER (Unique User Test)
# =====================================================
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "user_{{$timestamp}}",
  "password": "{{password}}",
  "companyName": "Test Company"
}

###

# =====================================================
# ❌ AUTH - ACCESS PROTECTED ROUTE (NO TOKEN)
# =====================================================
GET {{baseUrl}}/vehicles

###

# =====================================================
# ❌ AUTH - ACCESS PROTECTED ROUTE (INVALID TOKEN)
# =====================================================
GET {{baseUrl}}/vehicles
Authorization: Bearer invalidToken123

###

# =====================================================
# 🚗 VEHICLE - CREATE (Authenticated)
# =====================================================
POST {{baseUrl}}/vehicles
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiJwZXJzaXN0ZW50VXNlcjIiLCJpYXQiOjE3Nzc0MjYxMDQsImV4cCI6MTc3NzQyOTcwNH0.F6BKIgnfVmhJezMEM9s9ayFLbf6BAhQGXRmeSNI0K8vE2ERM4GBcjTzSVQgugb65
Content-Type: application/json

{
  "title": "Manual Test Vehicle",
  "make": "Toyota",
  "model": "Corolla",
  "vehicleYear": 2022,
  "location": "Test Garage",
  "maintenanceAlertsEnabled": true,
  "startDate": "2026-05-01",
  "endDate": "2026-12-31"
}

> {%
    console.log("CREATED VEHICLE:", response.body);
    client.global.set("vehicleId", response.body.data.id);
%}


